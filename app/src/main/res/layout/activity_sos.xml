<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="SOS"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Envie uma mensagem de emergência para um contato."
            android:textColor="@color/white_60"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_pill"
            android:hint="Número do contato"
            android:textColorHint="@color/white_60"
            android:inputType="phone"
            android:paddingVertical="16dp"
            android:paddingHorizontal="20dp"
            android:textColor="@color/white" />

        <EditText
            android:id="@+id/message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pill"
            android:hint="Mensagem de emergência"
            android:textColorHint="@color/white_60"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:paddingVertical="16dp"
            android:paddingHorizontal="20dp"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/send"
            style="@style/SetupPrimary"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_danger"
            android:text="Enviar SOS" />

        <TextView
            android:id="@+id/note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="O TeamOS abre o app de mensagens com o texto pronto — você confirma o envio."
            android:textColor="@color/white_60"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
