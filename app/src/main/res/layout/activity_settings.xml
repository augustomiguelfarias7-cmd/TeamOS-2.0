<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"
            android:text="Configurações"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout android:id="@+id/rowLanguage" style="@style/SettingsRow">
            <TextView android:id="@+id/rowLanguageTitle" style="@style/SettingsRowTitle" android:text="Idioma" />
            <TextView android:id="@+id/rowLanguageValue" style="@style/SettingsRowValue" android:text="Português (Brasil)" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowAssistant" style="@style/SettingsRow">
            <TextView android:id="@+id/rowAssistantTitle" style="@style/SettingsRowTitle" android:text="Assistente padrão" />
            <TextView android:id="@+id/rowAssistantValue" style="@style/SettingsRowValue" android:text="ChatGPT" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowSearch" style="@style/SettingsRow">
            <TextView android:id="@+id/rowSearchTitle" style="@style/SettingsRowTitle" android:text="Motor de busca" />
            <TextView android:id="@+id/rowSearchValue" style="@style/SettingsRowValue" android:text="Google" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowTeamAi" style="@style/SettingsRow">
            <TextView android:id="@+id/rowTeamAiTitle" style="@style/SettingsRowTitle" android:text="Team AI" />
            <TextView style="@style/SettingsRowValue" android:text="Pacote de IA" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowWellbeing" style="@style/SettingsRow">
            <TextView android:id="@+id/rowWellbeingTitle" style="@style/SettingsRowTitle" android:text="Bem-estar digital" />
            <TextView style="@style/SettingsRowValue" android:text="Tempo de uso" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
