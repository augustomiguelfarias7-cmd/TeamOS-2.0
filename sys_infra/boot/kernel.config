# TeamOS Linux Kernel Configuration (ARM64 & x86_64 base)
# Kernel Version: 6.8.0-teamos-v2

# Core System
CONFIG_ARM64=y
CONFIG_SMP=y
CONFIG_SCHED_MC=y
CONFIG_PREEMPT_RT=y
CONFIG_HZ_100=y

# Memory Management
CONFIG_SLUB=y
CONFIG_MMU=y
CONFIG_CMA=y
CONFIG_ZSMALLOC=y
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y

# Android Specific Kernel Features
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ASHMEM=y
CONFIG_ION=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# USB & Input Drivers
CONFIG_USB_SUPPORT=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_KEYBOARD=y

# Graphics and DRM
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_SIMPLE=y

# Networking
CONFIG_NET=y
CONFIG_WEXT_CORE=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
